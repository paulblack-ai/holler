# FreeSWITCH ESL
ESL_HOST=127.0.0.1
ESL_PORT=8021
ESL_PASSWORD=ClueCon

# SIP Trunk (configure with your provider)
TRUNK_HOST=sip.example.com
TRUNK_USER=your_username
TRUNK_PASSWORD=your_password
EXTERNAL_IP=auto

# LLM (OpenAI-compatible endpoint)
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llama3.2

# SignalWire (required to build FreeSWITCH Docker image)
SIGNALWIRE_TOKEN=your_signalwire_pat

# Voice Pipeline
WHISPER_MODEL=distil-large-v3
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
KOKORO_VOICE=af_sarah
